# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/devledger?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Anthropic API (platform.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MONTHLY_BUDGET_USD="30"

# Cloudflare R2 (S3-compatible file storage)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="devledger-files"
R2_PUBLIC_URL="https://files.yourdomain.com"

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="DevLedger <noreply@yourdomain.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
